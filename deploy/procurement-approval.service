[Unit]
Description=Procurement approval web app
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/procurement-approval
EnvironmentFile=/opt/procurement-approval/.env
ExecStart=/opt/procurement-approval/.venv/bin/gunicorn --workers 2 --bind 127.0.0.1:8000 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
